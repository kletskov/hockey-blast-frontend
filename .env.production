# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-this-in-production
SESSION_TYPE=filesystem
SESSION_PERMANENT=False
SESSION_COOKIE_SECURE=True

SITE_URL=https://hockey-blast.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=hockey_blast
DB_USER=frontend_user
DB_PASSWORD=hockey-blast
DB_HOST=db
DB_PORT=5432

DB_NAME_SAMPLE=hockey_blast_sample

DB_USER_BOSS=boss
DB_PASSWORD_BOSS=boss

# ── Auth0 ─────────────────────────────────────────────────────────────────────
# Configured client-side via auth0-spa-js. No server-side secrets needed.

# ── AI / Bedrock ──────────────────────────────────────────────────────────────
# AWS credentials should be configured via ~/.aws/credentials or environment variables
AWS_REGION=us-west-2
AI_SEARCH_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6
