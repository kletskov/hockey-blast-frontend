# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-this-in-production
SESSION_TYPE=filesystem
SESSION_PERMANENT=False
SESSION_COOKIE_SECURE=True

SITE_URL=https://hockey-blast.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=hockey_blast
DB_USER=frontend_user
DB_PASSWORD=hockey-blast
DB_HOST=db
DB_PORT=5432

DB_NAME_SAMPLE=hockey_blast_sample

DB_USER_BOSS=boss
DB_PASSWORD_BOSS=boss

# ── Auth0 ─────────────────────────────────────────────────────────────────────
# Configured client-side via auth0-spa-js. No server-side secrets needed.

# ── AI / Bedrock ──────────────────────────────────────────────────────────────
# Uses Bearer token auth (AWS Bedrock API Key, not IAM)
# Same token as in hockey-blast-mcp/.env → AWS_BEARER_TOKEN_BEDROCK
AWS_REGION=us-west-2
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-6
AWS_BEARER_TOKEN_BEDROCK=

# ── Video highlights service ─────────────────────────────────────────────────
VIDEO_SERVICE_URL=http://127.0.0.1:5004
